{
  "name": "lumesync-workspace",
  "version": "1.0.0",
  "description": "萤火课堂 - AI-powered face recognition LAN classroom sync tool",
  "private": true,
  "scripts": {
    "repos:init": "git submodule sync --recursive && git submodule update --init --recursive",
    "repos:update": "git submodule update --remote --merge --recursive",
    "start:core": "npm --prefix repos/core run start",
    "start:teacher": "npm --prefix repos/teacher run start",
    "start:teacher-server": "npm --prefix repos/teacher run start:server",
    "start:student": "npm --prefix repos/student run start",
    "build:verify": "pkg shared/build/verify-password.js --target node18-win-x64 --output shared/build/verify-password.exe",
    "build:icons": "python shared/build/convert-icons.py",
    "build:icons:js": "node shared/build/convert-icons.js",
    "migrate": "node migrate-all.js"
  },
  "dependencies": {
    "archiver": "^6.0.1",
    "auto-launch": "^5.0.6",
    "axios": "^1.13.6",
    "builder-util": "^26.8.1",
    "express": "^4.18.2",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "7zip-bin": "^5.2.0",
    "app-builder-bin": "^5.0.0-alpha.12",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "node-windows": "^1.0.0-beta.8",
    "pkg": "^5.8.1",
    "png-to-ico": "^3.0.1",
    "socket.io-client": "^4.8.3"
  }
}
